{
  "name": "ordinales-js",
  "version": "2.3.0",
  "description": "Librería para convertir números cardinales a ordinales en español. Spanish ordinal numbers library with gender and apocope support.",
  "main": "./src/index.js",
  "types": "./src/ordinales.d.ts",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/ordinales.mjs",
      "types": "./src/ordinales.d.ts"
    }
  },
  "files": [
    "src/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test test.mjs",
    "lint": "eslint src",
    "demo": "node demo.mjs",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndresSaa/ordinales-js.git"
  },
  "keywords": [
    "ordinal",
    "ordinales",
    "ordinal-es",
    "spanish-ordinal",
    "números-ordinales",
    "spanish-numbers",
    "ordinal-numbers",
    "español",
    "spanish",
    "cardinal-to-ordinal",
    "apocope"
  ],
  "author": "Andres Saa Narvaez <andres.saa.narvaez@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AndresSaa/ordinales-js/issues"
  },
  "homepage": "https://github.com/AndresSaa/ordinales-js#readme",
  "devDependencies": {
    "eslint": "^9.39.4"
  }
}
